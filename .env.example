# Build-time defaults embedded into app binaries (used if runtime env/JVM props are absent)
ELIXIR_DEFAULT_SERVER_HOST=192.168.1.50
ELIXIR_DEFAULT_SERVER_PORT=54555

# Space-separated Gradle Android tasks (example builds debug + release)
ANDROID_BUILD_TASKS=":android:assembleDebug :android:assembleRelease"

# Optional artifact naming override
# APP_NAME=ELIXIR-REIGN
# APP_VERSION=0.0.0

# Optional output folder
# OUTPUT_DIR=/absolute/path/to/artifacts

